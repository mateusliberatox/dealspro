# ── Supabase (server only — never expose to browser) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase (public — safe for browser) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Scraper ────────────────────────────────────────────────────────────────────
CSSDEALS_URL=https://cssdeals.com
HEADLESS=true

# ── Discord notifications ──────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...      # premium — fires immediately
DISCORD_FREE_WEBHOOK_URL=https://discord.com/api/webhooks/... # free — fires after 30 min
DISCORD_BOT_TOKEN=                                            # bot token (DMs + cargo premium)

# ── Discord servidor — cargo premium automático ────────────────────────────────
# Clique direito no servidor → Copiar ID
DISCORD_GUILD_ID=
# Clique direito no cargo premium → Copiar ID  (ativar Modo Desenvolvedor: Config → Avançado)
DISCORD_PREMIUM_ROLE_ID=

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cron trigger endpoint ──────────────────────────────────────────────────────
# Called by cron-job.org to bypass unreliable GitHub Actions scheduler
GH_PAT=ghp_...          # GitHub PAT with workflow scope (note: not GITHUB_ prefix)
CRON_SECRET=            # shared secret for /api/cron/trigger endpoint
