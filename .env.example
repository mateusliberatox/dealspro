# ── Supabase (server only — never expose to browser) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase (public — safe for browser) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Scraper ────────────────────────────────────────────────────────────────────
CSSDEALS_URL=https://cssdeals.com
HEADLESS=true
SCRAPE_INTERVAL_SECONDS=180          # intervalo do ciclo completo (homepage + categorias)
FAST_SCRAPE_INTERVAL_SECONDS=60      # intervalo do ciclo rápido
SCRAPE_MAX_CATEGORIES=20             # máximo de categorias por ciclo completo
SCRAPE_PAGES=1                       # páginas por categoria (1 = só novos; 2 = mais cobertura)
FAST_CATEGORY_IDS=18,11              # IDs de categoria incluídos no fast cycle (Fashion=18, Shoes=11)

# ── Traduções ──────────────────────────────────────────────────────────────────
# DeepL Free: 500k caracteres/mês — https://www.deepl.com/pro-api (plano Free)
# Se não configurado, usa MyMemory como fallback (1000 palavras/dia por IP)
DEEPL_API_KEY=

# ── Notificações free ──────────────────────────────────────────────────────────
FREE_NOTIFY_BATCH_SIZE=50            # máximo de produtos por ciclo de notificação free

# ── Health check ───────────────────────────────────────────────────────────────
PORT=3000                            # porta do servidor HTTP (Railway injeta automaticamente)

# ── Rastreamento de encomendas ────────────────────────────────────────────────
# O sistema detecta o provider automaticamente pela ordem abaixo:
#
# 1. TrackingMore — primário, aceita e-mail pessoal, 50 tracks/mês grátis
#    Cadastro: https://www.trackingmore.com → Dashboard → API Keys
TRACKINGMORE_API_KEY=
#
# 2. AfterShip — requer plano pago
#    Cadastro: https://www.aftership.com → Dashboard → API Keys
AFTERSHIP_API_KEY=
#
# 2. 17Track — secundário, requer e-mail empresarial
#    Cadastro: https://www.17track.net/en/api
SEVENTEEN_TRACK_API_KEY=
#
# 3. Correios direto — fallback automático, gratuito, sem cadastro
#    Funciona apenas para códigos BR* (encomendas já no Brasil)
#    Nenhuma variável necessária — ativado automaticamente se as acima não estiverem configuradas

# ID do app Discord (necessário para registrar slash commands)
DISCORD_APP_ID=

# ── Discord notifications ──────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...      # premium — fires immediately
DISCORD_FREE_WEBHOOK_URL=https://discord.com/api/webhooks/... # free — fires after 30 min
DISCORD_BOT_TOKEN=                                            # bot token (DMs + cargo premium)

# ── Discord servidor — cargo premium automático ────────────────────────────────
# Clique direito no servidor → Copiar ID
DISCORD_GUILD_ID=
# Clique direito no cargo premium → Copiar ID  (ativar Modo Desenvolvedor: Config → Avançado)
DISCORD_PREMIUM_ROLE_ID=

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cron trigger endpoint ──────────────────────────────────────────────────────
# Called by cron-job.org to bypass unreliable GitHub Actions scheduler
GH_PAT=ghp_...          # GitHub PAT with workflow scope (note: not GITHUB_ prefix)
CRON_SECRET=            # shared secret for /api/cron/trigger endpoint
