{
  "name": "dealspro",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "scrape:once": "tsx src/jobs/run-once.js",
    "monitor": "tsx src/entry/start-monitor.js",
    "test": "node --import tsx/esm --test src/utils/__tests__/hash.test.js src/utils/__tests__/categorize.test.js src/utils/__tests__/sizes.test.js src/utils/__tests__/productClassify.test.js src/utils/__tests__/alertMatch.test.js src/utils/__tests__/discordEmbed.test.js src/utils/__tests__/telegramMessage.test.js src/services/__tests__/pipeline.test.js",
    "test:lib": "node --import tsx/esm --test lib/__tests__/stripe-webhook.test.ts lib/__tests__/telegram-handlers.test.ts",
    "test:all": "npm test && npm run test:lib",
    "typecheck:src": "tsc --noEmit --project tsconfig.src.json",
    "build:src": "tsc --project tsconfig.src.build.json"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "dotenv": "^16.5.0",
    "next": "^15.3.2",
    "openai": "^6.39.1",
    "playwright": "1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.3.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
