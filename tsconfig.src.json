{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "paths": {}
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "src/**/__tests__", "src/**/*.js"]
}
